application/logs/*
!application/logs/.htaccess
application/cache/*
!application/cache/.htaccess
vendor/
assets/uploads/slips/*
!assets/uploads/slips/.gitkeep

# Local-only / sensitive files — never commit
try_ftp.php
*.tmp
*.zip
chk.php
test.php
info.php
phpinfo.php

# DB dumps — contain real student PII, must NOT be public
db/*.sql
!db/schema.sql

# One-time deploy/patch tools — contain secrets, never commit
deploy.php
patch.php
fix.php
